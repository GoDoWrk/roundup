APP_NAME=roundup
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://roundup:roundup@db:5432/roundup

MINIFLUX_BASE_URL=http://miniflux:8080
MINIFLUX_API_TOKEN=replace_with_token
MINIFLUX_FETCH_LIMIT=100

SCHEDULER_INTERVAL_SECONDS=600

CLUSTER_SCORE_THRESHOLD=0.55
CLUSTER_TIME_WINDOW_HOURS=72
CLUSTER_STALE_HOURS=48
CLUSTER_EMERGING_HOURS=24
CLUSTER_EMERGING_SOURCE_COUNT=3

API_DEFAULT_LIMIT=50
API_MAX_LIMIT=200
