APP_NAME=roundup
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Roundup application database
DATABASE_URL=postgresql+psycopg2://roundup:roundup@db:5432/roundup

# In normal mode Roundup expects live Miniflux credentials.
# docker-compose bootstraps Miniflux automatically and writes the API key file.
DEMO_MODE=false
MINIFLUX_URL=http://miniflux:8080
MINIFLUX_API_KEY=
MINIFLUX_API_KEY_FILE=/miniflux-bootstrap/miniflux_api_key
MINIFLUX_FETCH_LIMIT=100
MINIFLUX_TIMEOUT_SECONDS=20

# Demo-only fallback input (used only when DEMO_MODE=true)
SAMPLE_MINIFLUX_DATA_PATH=./data/sample_miniflux_entries.json

# Miniflux bootstrap/admin defaults (edit password at minimum)
MINIFLUX_ADMIN_USERNAME=roundup_admin
MINIFLUX_ADMIN_PASSWORD=change_this_roundup_admin_password
MINIFLUX_API_KEY_DESCRIPTION=Roundup ingestion API key
MINIFLUX_BOOTSTRAP_FEEDS_FILE=/app/data/miniflux_seed_feeds.json
MINIFLUX_BOOTSTRAP_DEFAULT_CATEGORY=Roundup Starter Feeds
MINIFLUX_POLLING_FREQUENCY=15
MINIFLUX_BOOTSTRAP_WAIT_SECONDS=240
MINIFLUX_BOOTSTRAP_RETRY_INTERVAL_SECONDS=3

# Miniflux internal database (used by miniflux-db service)
MINIFLUX_DB_USER=miniflux
MINIFLUX_DB_PASSWORD=miniflux
MINIFLUX_DB_NAME=miniflux

# Self-hosted runtime defaults are intentionally conservative.
API_WORKERS=1
INSPECTOR_WORKER_PROCESSES=1
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=600
INGESTION_CONCURRENCY=1
SUMMARIZATION_CONCURRENCY=1
CLUSTERING_BATCH_SIZE=100
CLUSTERING_CONCURRENCY=1

# Suggested profiles:
# Raspberry Pi / low power: API_WORKERS=1, INSPECTOR_WORKER_PROCESSES=1, INGESTION_CONCURRENCY=1, SUMMARIZATION_CONCURRENCY=1, CLUSTERING_BATCH_SIZE=50, CLUSTERING_CONCURRENCY=1
# Desktop / NAS: API_WORKERS=1, INSPECTOR_WORKER_PROCESSES=1, INGESTION_CONCURRENCY=1, SUMMARIZATION_CONCURRENCY=1, CLUSTERING_BATCH_SIZE=100, CLUSTERING_CONCURRENCY=1
# Larger server: API_WORKERS=2, INSPECTOR_WORKER_PROCESSES=2, INGESTION_CONCURRENCY=2, SUMMARIZATION_CONCURRENCY=2, CLUSTERING_BATCH_SIZE=250, CLUSTERING_CONCURRENCY=2

CLUSTER_SCORE_THRESHOLD=0.55
CLUSTER_TIME_WINDOW_HOURS=72
CLUSTER_TIE_BREAK_EPSILON=0.02
CLUSTER_MIN_TITLE_SIGNAL=0.72
CLUSTER_MIN_ENTITY_OVERLAP=1
CLUSTER_MIN_KEYWORD_OVERLAP=2
CLUSTER_MIN_TOPIC_SEMANTIC_SCORE=0.38
CLUSTER_ATTACH_OVERRIDE_MIN_TITLE_SIMILARITY=0.30
CLUSTER_ATTACH_OVERRIDE_MIN_TIME_PROXIMITY=0.80
CLUSTER_STALE_HOURS=48
CLUSTER_EMERGING_HOURS=24
CLUSTER_EMERGING_SOURCE_COUNT=3
CLUSTER_MIN_SOURCES_FOR_API=3
CLUSTER_MIN_HEADLINE_WORDS=3
CLUSTER_MIN_DETAIL_WORDS=8
TIMELINE_DEDUPE_WINDOW_HOURS=6
TIMELINE_DEDUPE_TITLE_SIMILARITY=0.85

API_DEFAULT_LIMIT=50
API_MAX_LIMIT=200
